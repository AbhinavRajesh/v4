# Spotify "Recently on repeat" mosaic
# Client credentials from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Cache for the Spotify access/refresh tokens used by /api/data/spotify
REDIS_URL=

# Shared secret that gates the internal /api/data/spotify route
API_KEY=

# Optional — Google Analytics
NEXT_PUBLIC_GA_ID=
